# Variables de entorno para Producción
# Copia este archivo como referencia y configura los valores reales
# únicamente en tu proveedor (Render/Vercel), no en git.

# Backend - Variables para Render
PORT=5000
NODE_ENV=production

# MongoDB Atlas (requerido para producción en la nube)
MONGODB_URI=REEMPLAZAR_CON_MONGODB_URI

# JWT Secret (generar uno seguro)
JWT_SECRET=REEMPLAZAR_CON_JWT_SECRET

# Frontend - Variables para Vercel
VITE_API_URL=https://compraventa-backend.onrender.com/api

# Seguridad backend
# Dejar en false en producción. Activar temporalmente solo para bootstrap inicial.
ALLOW_SETUP_ADMIN=false
# En producción define explícitamente dominios permitidos separados por coma.
# Ejemplo: https://tu-frontend.vercel.app,https://www.tudominio.com
ALLOWED_ORIGINS=
