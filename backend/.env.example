# Variables de entorno para el Backend
# Copiar este archivo a .env y completar con valores reales

# Puerto del servidor
PORT=5000

# Variables de MongoDB
# Para MongoDB local:
# MONGODB_URI=mongodb://localhost:27017/compraventa-vehiculos

# Para MongoDB Atlas (recomendado para móviles):
# MONGODB_URI=mongodb+srv://<usuario>:<contraseña>@<cluster>.mongodb.net/<base-datos>?retryWrites=true&w=majority

MONGODB_URI=mongodb://localhost:27017/compraventa-vehiculos

# Secreto para JWT (cambiar por un valor seguro y aleatorio)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=tu_secreto_jwt_muy_seguro_aqui_cambiar_en_produccion

# Entorno
NODE_ENV=development
