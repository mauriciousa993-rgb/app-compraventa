# Variables de entorno para el Backend
# Copiar este archivo a .env y completar con valores reales

# Puerto del servidor
PORT=5000

# Variables de MongoDB
# Para MongoDB local:
# MONGODB_URI=mongodb://localhost:27017/compraventa-vehiculos

# Para MongoDB Atlas (recomendado para móviles):
MONGODB_URI=mongodb+srv://mvillacar:mvillacar123@mvillacar.1uocybr.mongodb.net/compraventa-vehiculos?retryWrites=true&w=majority

# Secreto para JWT (cambiar por un valor seguro y aleatorio)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=d3f4u1t_jwt_s3cr3t_ch4ng3_th1s_p1s

# Entorno
NODE_ENV=production

# Cloudinary (opcional - para almacenamiento de fotos en la nube)
# Obtener credenciales en: https://cloudinary.com
# CLOUDINARY_CLOUD_NAME=tu_cloud_name
# CLOUDINARY_API_KEY=tu_api_key
# CLOUDINARY_API_SECRET=tu_api_secret

# OCR con IA (opcional - fallback al OCR local si no se configura)
# Obtener API Key en: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_VISION_MODEL=gpt-4o-mini
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# Directorio de uploads (opcional)
# UPLOAD_DIR=./uploads
