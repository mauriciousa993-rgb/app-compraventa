{
  "buildCommand": "rm -rf node_modules .next dist && npm ci && vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "@vite_api_url"
  },
  "build": {
    "env": {
      "CI": "false",
      "NODE_ENV": "production"
    }
  }
}
