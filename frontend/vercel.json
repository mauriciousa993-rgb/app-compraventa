{
  "buildCommand": "npm install && vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "@vite_api_url"
  },
  "build": {
    "env": {
      "CI": "false",
      "SKIP_PREFLIGHT_CHECK": "true",
      "TSC_COMPILE_ON_ERROR": "true"
    }
  }
}
