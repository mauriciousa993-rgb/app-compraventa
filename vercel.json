{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "build": {
    "env": {
      "FORCE_REBUILD": "true",
      "REBUILD_TIMESTAMP": "2025-01-13-force-redeploy-v3"
    }
  }
}
